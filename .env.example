# Optional: official Reddit API (script app) — Reddit source is skipped until these are set
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional: GitHub personal access token — raises search rate limit from 10 to 30 req/min.
# No scopes needed (public data). Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# Required for the AI scoring + writeup stage (npm run score / backfill scoring)
ANTHROPIC_API_KEY=

# Optional: Product Hunt v2 API — unlocks vote-ranked, topic-filtered pulls
# (popular + relevant tools, with upvote counts + thumbnails). Without it, the
# Product Hunt source falls back to the keyless Atom feed (newest only, no votes).
# Free at producthunt.com → API dashboard → create an application. Paste the
# application's API Key + API Secret below (the adapter exchanges them for a token).
PRODUCTHUNT_KEY=
PRODUCTHUNT_SECRET=
# Alternatively, a single Developer Token also works in place of the two above:
# PRODUCTHUNT_TOKEN=

# Hacker News (Algolia) and Are.na need no credentials.
