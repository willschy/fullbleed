---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"entries">;
  index?: number;
  feature?: boolean;
}

const { entry, index = 0, feature = false } = Astro.props;
const d = entry.data;

// responsive cover: 480 / 960 / 1333 WebP — grid grabs the small ones, hero pulls full
const hasCover = d.thumbnail?.endsWith("-cover.webp");
const smThumb = hasCover ? d.thumbnail!.replace("-cover.webp", "-cover-sm.webp") : null;
const mdThumb = hasCover ? d.thumbnail!.replace("-cover.webp", "-cover-md.webp") : null;
const coverSrcset = hasCover
  ? `${smThumb} 480w, ${mdThumb} 960w, ${d.thumbnail} 1333w`
  : undefined;
const imgSizes = "(max-width: 640px) 92vw, (max-width: 1100px) 45vw, 30vw";

// Type label for the kicker — concise singular forms (the rail still uses the full names).
const TYPE_KICKER: Record<string, string> = {
  "tools": "Tool",
  "automations": "Automation",
  "models": "Model",
  "plugins-skills": "Skill",
  "papers": "Paper",
};
const typeLabel = TYPE_KICKER[d.category] ?? "Tool";
const discipline = d.disciplines[0] ?? null;

const ageDays = (Date.now() - d.date.valueOf()) / 86_400_000;
const freshness = d.supersededBy ? "superseded" : ageDays <= 30 ? "fresh" : ageDays <= 180 ? "aging" : "old";
const stamp = d.date
  .toLocaleDateString("en-US", { month: "short", day: "numeric" })
  .toUpperCase();
---

<article
  class={`card ${feature ? "is-feature" : ""}`}
  style={`animation-delay: ${Math.min(index, 10) * 45}ms`}
  data-id={entry.id}
  data-category={d.category}
  data-tools={d.tools.join("|")}
  data-disciplines={d.disciplines.join("|")}
  data-superseded={d.supersededBy ? "true" : "false"}
>
  <a class="card-link" href={`/entry/${entry.id}/`} aria-label={d.title}>
    <div class="card-media">
      {d.thumbnail && (
        <img
          class="card-img"
          src={smThumb ?? d.thumbnail}
          srcset={coverSrcset}
          sizes={coverSrcset ? imgSizes : undefined}
          alt=""
          loading={feature ? "eager" : "lazy"}
          width="800"
          height="600"
        />
      )}

      {freshness === "superseded" && (
        <span class="badge badge-superseded">Superseded</span>
      )}
      {freshness === "fresh" && (
        <span class="badge badge-fresh"><span class="dot" aria-hidden="true"></span>New</span>
      )}
    </div>

    <div class="card-body">
      <div class="card-kicker">
        <span class="k-cat">
          {typeLabel}{discipline && <span class="k-sep"> · </span>}{discipline && <span class="k-disc">{discipline}</span>}
        </span>
        <span class="k-date">{stamp}</span>
      </div>
      <h3 class="card-title">{d.title}</h3>
      <p class="card-digest">{d.hoverWhat}</p>
    </div>
  </a>

  <button class="card-save" type="button" data-bookmark data-id={entry.id} aria-label="Save to your list" aria-pressed="false">
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
      <path d="M6 4.5h12a1 1 0 0 1 1 1v14l-7-4-7 4v-14a1 1 0 0 1 1-1z" />
    </svg>
  </button>
</article>

<style>
  .card {
    --ease-calm: cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: var(--shadow-rest);
    transition: transform 0.4s var(--ease-calm), box-shadow 0.4s var(--ease-out), border-color 0.3s var(--ease-out);
    animation: card-rise 0.55s var(--ease-out) backwards;
  }

  @keyframes card-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
    -webkit-tap-highlight-color: transparent;
  }

  /* ------- image zone ------- */
  .card-media {
    position: relative;
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: var(--paper);
    isolation: isolate;
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease-out);
  }

  /* floating status badge — solid fill, no backdrop-filter */
  .badge {
    position: absolute;
    top: 11px;
    left: 11px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    border-radius: var(--r-pill);
    background: rgba(10, 10, 9, 0.5);
    font-size: 0.6875rem;
    font-weight: var(--w-med);
    letter-spacing: 0.02em;
    color: #fff;
  }

  .badge-superseded .dot,
  .badge-superseded::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* save button — over the media, top-right; outside the link so it never navigates */
  .card-save {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 5;
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: rgba(10, 10, 9, 0.5);
    color: #fff;
    cursor: pointer;
    opacity: 0;
    transform: translateY(-4px) scale(0.92);
    transition: opacity 0.3s var(--ease-out), transform 0.4s var(--ease-calm), background 0.2s var(--ease-out);
  }

  .card-save svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linejoin: round;
    transition: fill 0.2s var(--ease-out);
  }

  .card-save:hover {
    background: rgba(10, 10, 9, 0.7);
  }

  .card-save:active {
    transform: scale(0.86);
  }

  /* saved: filled vermillion bookmark, always visible */
  .card-save.is-saved {
    opacity: 1;
    transform: none;
  }

  .card-save.is-saved svg {
    fill: var(--accent);
    stroke: var(--accent);
  }

  .card:hover .card-save,
  .card:focus-within .card-save {
    opacity: 1;
    transform: none;
  }

  /* ------- content block ------- */
  .card-body {
    padding: 12px 13px 14px;
  }

  .card-kicker {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 8px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .k-cat {
    color: rgba(242, 241, 236, 0.82);
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .k-disc {
    color: #ff7a4d;
  }

  .k-date {
    color: var(--ink-35);
    white-space: nowrap;
    flex: none;
  }

  .card-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: var(--w-med);
    line-height: 1.32;
    color: var(--ink);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* reserve 2 lines so every card is the same height regardless of title length */
    min-height: calc(1.32em * 2);
  }

  .card-digest {
    margin: 7px 0 0;
    font-size: 0.8125rem;
    font-weight: var(--w-body);
    line-height: 1.5;
    color: rgba(242, 241, 236, 0.62);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    /* reserve 2 lines so every card is the same height regardless of digest length */
    min-height: calc(1.5em * 2);
  }

  /* ------- hover (pointer only) ------- */
  @media (hover: hover) {
    .card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-lift);
      border-color: rgba(242, 241, 236, 0.2);
      z-index: 20;
    }

    .card:hover .card-img {
      transform: scale(1.04);
    }
  }
</style>
