---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"entries">;
  index?: number;
}

const { entry, index = 0 } = Astro.props;
const d = entry.data;

const CATEGORY_LABELS: Record<string, string> = {
  "client-work": "Client Work",
  "tools-you-can-steal": "Steal This",
  "new-possible": "New Possible",
  "business-plays": "Business Play",
};

const ageDays = (Date.now() - d.date.valueOf()) / 86_400_000;
const freshness = d.supersededBy ? "superseded" : ageDays <= 30 ? "fresh" : ageDays <= 180 ? "aging" : "old";
const stamp = d.date
  .toLocaleDateString("en-US", { month: "short", day: "numeric" })
  .toUpperCase();
---

<article
  class="card"
  style={`animation-delay: ${Math.min(index, 10) * 45}ms`}
  data-category={d.category}
  data-tools={d.tools.join("|")}
  data-superseded={d.supersededBy ? "true" : "false"}
>
  <a class="card-link" href={`/entry/${entry.id}/`} aria-label={d.title}>
    {d.thumbnail && <img class="card-img" src={d.thumbnail} alt="" loading="lazy" width="800" height="600" />}

    {freshness === "superseded" && (
      <span class="badge badge-superseded">Superseded</span>
    )}
    {freshness === "fresh" && (
      <span class="badge badge-fresh"><span class="dot" aria-hidden="true"></span>New</span>
    )}

    <div class="card-veil" aria-hidden="true"></div>

    <div class="card-face">
      <h3 class="card-title">{d.title}</h3>
      <span class="card-stamp">{stamp}</span>
    </div>

    <div class="card-panel">
      <div class="panel-tags">
        <span class="tag">{CATEGORY_LABELS[d.category]}</span>
        {d.tools.slice(0, 2).map((t) => <span class="tag tag-tool">{t}</span>)}
      </div>
      <p class="panel-what">{d.hoverWhat}</p>
      <p class="panel-why">{d.hoverWhy}</p>
    </div>
  </a>
</article>

<style>
  .card {
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-rest);
    transition: transform var(--dur) var(--ease-spring), box-shadow var(--dur) var(--ease-out);
    animation: card-rise 0.55s var(--ease-out) backwards;
  }

  @keyframes card-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .card-link {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--surface);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    isolation: isolate;
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  /* gradient veil that grows on hover so panel text always reads */
  .card-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10, 10, 9, 0.62) 0%, rgba(10, 10, 9, 0.18) 26%, transparent 48%);
    opacity: 0.9;
    transition: opacity var(--dur) var(--ease-out);
  }

  /* floating status badges */
  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    border-radius: var(--r-pill);
    background: var(--glass);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 0.6875rem;
    font-weight: var(--w-med);
    letter-spacing: 0.02em;
    color: var(--ink-70);
  }

  .badge-superseded {
    color: var(--accent);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* resting face: title + date over the image's lower edge */
  .card-face {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s3);
    padding: var(--s4);
    transition: opacity var(--dur-fast) var(--ease-out), transform var(--dur) var(--ease-out);
  }

  .card-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: var(--w-med);
    line-height: 1.3;
    color: #fff;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.25);
  }

  .card-stamp {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.75);
    white-space: nowrap;
  }

  /* hover panel: glass sheet that rises inside the card — one object */
  .card-panel {
    position: absolute;
    inset-inline: 10px;
    bottom: 10px;
    z-index: 3;
    border-radius: var(--r-md);
    background: var(--glass);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow: 0 4px 24px -8px rgba(10, 10, 9, 0.3);
    padding: var(--s4);
    opacity: 0;
    transform: translateY(14px) scale(0.98);
    pointer-events: none;
    transition: opacity var(--dur) var(--ease-out), transform var(--dur) var(--ease-spring);
  }

  .panel-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: var(--s3);
  }

  .tag {
    padding: 3px 9px;
    border-radius: var(--r-pill);
    background: var(--ink);
    color: var(--paper);
    font-size: 0.6563rem;
    font-weight: var(--w-med);
    letter-spacing: 0.02em;
  }

  .tag-tool {
    background: rgba(19, 19, 18, 0.07);
    color: var(--ink-70);
  }

  .panel-what {
    margin: 0;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--ink);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .panel-why {
    margin: var(--s2) 0 0;
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--ink-70);
    border-left: 2px solid var(--accent);
    padding-left: var(--s3);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ------- open state ------- */
  .card.is-open {
    transform: translateY(-4px) scale(1.015);
    box-shadow: var(--shadow-lift);
    z-index: 20;
  }

  .card.is-open .card-img {
    transform: scale(1.045);
  }

  .card.is-open .card-veil {
    opacity: 0.4;
  }

  .card.is-open .card-face {
    opacity: 0;
    transform: translateY(-6px);
  }

  .card.is-open .card-panel {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
</style>
