---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"entries">;
  index?: number;
  feature?: boolean;
}

const { entry, index = 0, feature = false } = Astro.props;
const d = entry.data;

// responsive cover: 480 / 960 / 1333 WebP — grid grabs the small ones, hero pulls full
const hasCover = d.thumbnail?.endsWith("-cover.webp");
const smThumb = hasCover ? d.thumbnail!.replace("-cover.webp", "-cover-sm.webp") : null;
const mdThumb = hasCover ? d.thumbnail!.replace("-cover.webp", "-cover-md.webp") : null;
const coverSrcset = hasCover
  ? `${smThumb} 480w, ${mdThumb} 960w, ${d.thumbnail} 1333w`
  : undefined;
const imgSizes = feature
  ? "(max-width: 859px) 92vw, 64vw"
  : "(max-width: 640px) 92vw, (max-width: 1100px) 45vw, 30vw";

const CATEGORY_LABELS: Record<string, string> = {
  "tools": "Tools",
  "automations": "Automations",
  "models": "Models",
  "plugins-skills": "Plugins & Skills",
  "papers": "Papers",
};

const ageDays = (Date.now() - d.date.valueOf()) / 86_400_000;
const freshness = d.supersededBy ? "superseded" : ageDays <= 30 ? "fresh" : ageDays <= 180 ? "aging" : "old";
const stamp = d.date
  .toLocaleDateString("en-US", { month: "short", day: "numeric" })
  .toUpperCase();
---

<article
  class={`card ${feature ? "is-feature" : ""}`}
  style={`animation-delay: ${Math.min(index, 10) * 45}ms`}
  data-id={entry.id}
  data-category={d.category}
  data-tools={d.tools.join("|")}
  data-disciplines={d.disciplines.join("|")}
  data-superseded={d.supersededBy ? "true" : "false"}
>
  <a class="card-link" href={`/entry/${entry.id}/`} aria-label={d.title}>
    {d.thumbnail && (
      <img
        class="card-img"
        src={smThumb ?? d.thumbnail}
        srcset={coverSrcset}
        sizes={coverSrcset ? imgSizes : undefined}
        alt=""
        loading={feature ? "eager" : "lazy"}
        width="800"
        height="600"
      />
    )}

    <div class="card-veil" aria-hidden="true"></div>

    {freshness === "superseded" && (
      <span class="badge badge-superseded">Superseded</span>
    )}
    {freshness === "fresh" && (
      <span class="badge badge-fresh"><span class="dot" aria-hidden="true"></span>New</span>
    )}

    <div class="card-content">
      <div class="card-reveal">
        <div class="card-reveal-inner">
          <div class="reveal-tags">
            <span class="tag tag-cat">{CATEGORY_LABELS[d.category]}</span>
            {d.tools.slice(0, 2).map((t) => <span class="tag">{t}</span>)}
          </div>
          <p class="reveal-why">{d.hoverWhy}</p>
        </div>
      </div>
      <div class="card-face">
        <h3 class="card-title">{d.title}</h3>
        <span class="card-stamp">{stamp}</span>
      </div>
    </div>
  </a>

  <button class="card-save" type="button" data-bookmark data-id={entry.id} aria-label="Save to your list" aria-pressed="false">
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
      <path d="M6 4.5h12a1 1 0 0 1 1 1v14l-7-4-7 4v-14a1 1 0 0 1 1-1z" />
    </svg>
  </button>
</article>

<style>
  /* calm, no-overshoot easing for the reveal — premium, not bouncy */
  .card {
    --ease-calm: cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-rest);
    transition: transform 0.4s var(--ease-calm), box-shadow 0.4s var(--ease-out);
    animation: card-rise 0.55s var(--ease-out) backwards;
  }

  @keyframes card-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .card-link {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--surface);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    isolation: isolate;
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* radius lives on the img too so view-transition snapshots stay rounded mid-morph */
    border-radius: var(--r-lg);
    transition: transform 0.7s var(--ease-out);
  }

  /* cinematic gradient — the image is always the substrate, never an opaque sheet */
  .card-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 8, 7, 0.7) 0%,
      rgba(8, 8, 7, 0.32) 22%,
      rgba(8, 8, 7, 0.04) 42%,
      transparent 60%
    );
    transition: opacity var(--dur) var(--ease-out);
  }

  /* floating status badge — solid fill, no backdrop-filter */
  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    border-radius: var(--r-pill);
    background: rgba(10, 10, 9, 0.5);
    font-size: 0.6875rem;
    font-weight: var(--w-med);
    letter-spacing: 0.02em;
    color: #fff;
  }

  .badge-superseded {
    color: #fff;
  }

  .badge-superseded .dot,
  .badge-superseded::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* save button — over the card (outside the link), top-right */
  .card-save {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 5;
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    border: none;
    border-radius: 50%;
    background: rgba(10, 10, 9, 0.5);
    color: #fff;
    opacity: 0;
    transform: translateY(-4px) scale(0.92);
    transition: opacity 0.3s var(--ease-out), transform 0.4s var(--ease-calm), background 0.2s var(--ease-out);
  }

  .card-save svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linejoin: round;
    transition: fill 0.2s var(--ease-out);
  }

  .card-save:hover {
    background: rgba(10, 10, 9, 0.7);
  }

  .card-save:active {
    transform: scale(0.86);
  }

  /* saved: filled vermillion bookmark, always visible */
  .card-save.is-saved {
    opacity: 1;
    transform: none;
    color: #fff;
  }

  .card-save.is-saved svg {
    fill: var(--accent);
    stroke: var(--accent);
  }

  /* reveal the save affordance on hover / when open (touch), or if already saved */
  .card:hover .card-save,
  .card.is-open .card-save {
    opacity: 1;
    transform: none;
  }

  /* bottom-anchored content; reveal slides up from behind the always-on title */
  .card-content {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    padding: var(--s4);
  }

  /* grid-rows 0fr→1fr is the smooth, clipped height reveal (no janky max-height) */
  .card-reveal {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s var(--ease-calm);
  }

  .card-reveal-inner {
    overflow: hidden;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.4s var(--ease-out), transform 0.55s var(--ease-calm);
  }

  .reveal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    padding-bottom: var(--s3);
  }

  .tag {
    padding: 3px 9px;
    border-radius: var(--r-pill);
    background: rgba(10, 10, 9, 0.5);
    color: #fff;
    font-size: 0.6563rem;
    font-weight: var(--w-med);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .tag-cat {
    background: #fff;
    color: #131312;
  }

  .reveal-why {
    margin: 0 0 var(--s3);
    font-size: 0.8438rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.94);
    border-left: 2px solid var(--accent);
    padding-left: var(--s3);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.45);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-face {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s3);
  }

  .card-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: var(--w-med);
    line-height: 1.3;
    color: #fff;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.45);
  }

  .card-stamp {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.78);
    white-space: nowrap;
    flex: none;
  }

  /* ------- feature (lead story) ------- */
  /* spans 2 columns; ratio chosen so its height matches a 4:3 neighbor (2w + gap) */
  .card.is-feature .card-link {
    aspect-ratio: 2.72 / 1;
  }

  .card.is-feature .card-title {
    font-size: 1.1875rem;
  }

  .card.is-feature .reveal-why {
    max-width: 46ch;
  }

  @media (max-width: 859px) {
    .card.is-feature .card-link {
      aspect-ratio: 4 / 3;
    }

    .card.is-feature .card-title {
      font-size: 0.9375rem;
    }
  }

  /* ------- open state (.is-open for touch, :hover for pointers) ------- */
  .card.is-open {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
    z-index: 20;
  }

  .card.is-open .card-img {
    transform: scale(1.04);
  }

  .card.is-open .card-reveal {
    grid-template-rows: 1fr;
  }

  .card.is-open .card-reveal-inner {
    opacity: 1;
    transform: none;
  }

  @media (hover: hover) {
    .card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-lift);
      z-index: 20;
    }

    .card:hover .card-img {
      transform: scale(1.04);
    }

    .card:hover .card-reveal {
      grid-template-rows: 1fr;
    }

    .card:hover .card-reveal-inner {
      opacity: 1;
      transform: none;
    }
  }

  /* the deepening of the gradient on hover: scale its alpha via a second layer */
  .card-veil::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8, 8, 7, 0.55) 0%, rgba(8, 8, 7, 0.12) 35%, transparent 65%);
    opacity: 0;
    transition: opacity var(--dur) var(--ease-out);
  }

  .card.is-open .card-veil::after {
    opacity: 1;
  }

  @media (hover: hover) {
    .card:hover .card-veil::after {
      opacity: 1;
    }
  }
</style>
