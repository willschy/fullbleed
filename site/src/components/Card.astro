---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"entries">;
  index?: number;
  feature?: boolean;
}

const { entry, index = 0, feature = false } = Astro.props;
const d = entry.data;

const CATEGORY_LABELS: Record<string, string> = {
  "client-work": "Client Work",
  "tools-you-can-steal": "Steal This",
  "new-possible": "New Possible",
  "business-plays": "Business Play",
};

const ageDays = (Date.now() - d.date.valueOf()) / 86_400_000;
const freshness = d.supersededBy ? "superseded" : ageDays <= 30 ? "fresh" : ageDays <= 180 ? "aging" : "old";
const stamp = d.date
  .toLocaleDateString("en-US", { month: "short", day: "numeric" })
  .toUpperCase();
---

<article
  class={`card ${feature ? "is-feature" : ""}`}
  style={`animation-delay: ${Math.min(index, 10) * 45}ms`}
  data-category={d.category}
  data-tools={d.tools.join("|")}
  data-superseded={d.supersededBy ? "true" : "false"}
>
  <a class="card-link" href={`/entry/${entry.id}/`} aria-label={d.title}>
    {d.thumbnail && (
      <img
        class="card-img"
        src={d.thumbnail}
        alt=""
        loading={feature ? "eager" : "lazy"}
        width="800"
        height="600"
        transition:name={`hero-${entry.id}`}
      />
    )}

    <div class="card-veil" aria-hidden="true"></div>

    {freshness === "superseded" && (
      <span class="badge badge-superseded">Superseded</span>
    )}
    {freshness === "fresh" && (
      <span class="badge badge-fresh"><span class="dot" aria-hidden="true"></span>New</span>
    )}

    <span class="card-open" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M7 17 17 7M9 7h8v8" />
      </svg>
    </span>

    <div class="card-content">
      <div class="card-reveal">
        <div class="reveal-tags">
          <span class="tag tag-cat">{CATEGORY_LABELS[d.category]}</span>
          {d.tools.slice(0, 2).map((t) => <span class="tag">{t}</span>)}
        </div>
        <p class="reveal-why">{d.hoverWhy}</p>
      </div>
      <div class="card-face">
        <h3 class="card-title">{d.title}</h3>
        <span class="card-stamp">{stamp}</span>
      </div>
    </div>
  </a>
</article>

<style>
  .card {
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-rest);
    transition: transform var(--dur) var(--ease-spring), box-shadow var(--dur) var(--ease-out);
    animation: card-rise 0.55s var(--ease-out) backwards;
  }

  @keyframes card-rise {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .card-link {
    position: relative;
    display: block;
    aspect-ratio: 4 / 3;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: var(--surface);
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    isolation: isolate;
  }

  .card-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* radius lives on the img too so view-transition snapshots stay rounded mid-morph */
    border-radius: var(--r-lg);
    transition: transform 0.5s var(--ease-out);
  }

  /* cinematic gradient — the image is always the substrate, never an opaque sheet */
  .card-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(8, 8, 7, 0.7) 0%,
      rgba(8, 8, 7, 0.32) 22%,
      rgba(8, 8, 7, 0.04) 42%,
      transparent 60%
    );
    transition: opacity var(--dur) var(--ease-out);
  }

  /* floating status badge */
  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    border-radius: var(--r-pill);
    background: var(--glass);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 0.6875rem;
    font-weight: var(--w-med);
    letter-spacing: 0.02em;
    color: var(--ink-70);
  }

  .badge-superseded {
    color: var(--accent);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  /* "opens" cue — appears on hover, signals the card is a doorway */
  .card-open {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: #fff;
    opacity: 0;
    transform: scale(0.8);
    transition: opacity var(--dur-fast) var(--ease-out), transform var(--dur) var(--ease-spring);
  }

  /* bottom-anchored content; reveal grows upward above the always-on title */
  .card-content {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    padding: var(--s4);
  }

  .card-reveal {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transform: translateY(6px);
    transition:
      max-height var(--dur-slow) var(--ease-out),
      opacity var(--dur) var(--ease-out),
      transform var(--dur-slow) var(--ease-spring);
  }

  .reveal-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    padding-bottom: var(--s3);
  }

  .tag {
    padding: 3px 9px;
    border-radius: var(--r-pill);
    background: rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #fff;
    font-size: 0.6563rem;
    font-weight: var(--w-med);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .tag-cat {
    background: #fff;
    color: #131312;
  }

  .reveal-why {
    margin: 0 0 var(--s3);
    font-size: 0.8438rem;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.92);
    border-left: 2px solid var(--accent);
    padding-left: var(--s3);
    text-shadow: 0 1px 10px rgba(0, 0, 0, 0.4);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-face {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--s3);
  }

  .card-title {
    margin: 0;
    font-size: 0.9375rem;
    font-weight: var(--w-med);
    line-height: 1.3;
    color: #fff;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.45);
  }

  .card-stamp {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.78);
    white-space: nowrap;
    flex: none;
  }

  /* ------- feature (lead story) ------- */
  /* spans 2 columns; ratio chosen so its height matches a 4:3 neighbor (2w + gap) */
  .card.is-feature .card-link {
    aspect-ratio: 2.72 / 1;
  }

  .card.is-feature .card-title {
    font-size: 1.1875rem;
  }

  .card.is-feature .reveal-why {
    max-width: 46ch;
  }

  @media (max-width: 859px) {
    .card.is-feature .card-link {
      aspect-ratio: 4 / 3;
    }

    .card.is-feature .card-title {
      font-size: 0.9375rem;
    }
  }

  /* ------- open state (.is-open for touch, :hover for pointers) ------- */
  .card.is-open {
    transform: translateY(-5px) scale(1.012);
    box-shadow: var(--shadow-lift);
    z-index: 20;
  }

  .card.is-open .card-img {
    transform: scale(1.06);
  }

  .card.is-open .card-open {
    opacity: 1;
    transform: none;
  }

  .card.is-open .card-reveal {
    max-height: 180px;
    opacity: 1;
    transform: none;
  }

  @media (hover: hover) {
    .card:hover {
      transform: translateY(-5px) scale(1.012);
      box-shadow: var(--shadow-lift);
      z-index: 20;
    }

    .card:hover .card-img {
      transform: scale(1.06);
    }

    .card:hover .card-open {
      opacity: 1;
      transform: none;
    }

    .card:hover .card-reveal {
      max-height: 180px;
      opacity: 1;
      transform: none;
    }
  }

  /* the deepening of the gradient on hover: scale its alpha via a second layer */
  .card-veil::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(8, 8, 7, 0.55) 0%, rgba(8, 8, 7, 0.12) 35%, transparent 65%);
    opacity: 0;
    transition: opacity var(--dur) var(--ease-out);
  }

  .card.is-open .card-veil::after {
    opacity: 1;
  }

  @media (hover: hover) {
    .card:hover .card-veil::after {
      opacity: 1;
    }
  }
</style>
