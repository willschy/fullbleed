---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"entries">;
}

const { entry } = Astro.props;
const d = entry.data;

const CATEGORY_LABELS: Record<string, string> = {
  "client-work": "Client Work",
  "tools-you-can-steal": "Steal This",
  "new-possible": "New Possible",
  "business-plays": "Business Play",
};

const ageDays = (Date.now() - d.date.valueOf()) / 86_400_000;
const freshness = d.supersededBy ? "superseded" : ageDays <= 30 ? "fresh" : ageDays <= 180 ? "aging" : "old";
const stamp = d.date
  .toLocaleDateString("en-US", { month: "short", day: "2-digit", year: "numeric" })
  .replace(",", "")
  .toUpperCase();
---

<article
  class="card"
  data-category={d.category}
  data-tools={d.tools.join("|")}
  data-superseded={d.supersededBy ? "true" : "false"}
>
  <a class="card-link" href={`/entry/${entry.id}/`}>
    <div class="card-media">
      {d.thumbnail && <img src={d.thumbnail} alt={d.title} loading="lazy" width="800" height="600" />}
      <div class="card-marks" aria-hidden="true"></div>
    </div>
    <div class="card-bar">
      <span class="meta card-cat">{CATEGORY_LABELS[d.category]}</span>
      <span class="meta card-tool">{d.tools[0]}</span>
    </div>
    <h3 class="card-title">{d.title}</h3>
    <div class={`meta card-stamp is-${freshness}`}>
      {freshness === "fresh" && <span class="dot" aria-hidden="true"></span>}
      <span>{stamp}</span>
      {freshness === "superseded" && <span class="superseded-mark">superseded — see current</span>}
    </div>
  </a>
  <div class="card-digest" aria-hidden="true">
    <p class="digest-what">{d.hoverWhat}</p>
    <p class="digest-why">{d.hoverWhy}</p>
    <p class="meta digest-stack">{d.tools.join(" · ")}</p>
  </div>
</article>

<style>
  .card {
    position: relative;
    transition: transform var(--dur) var(--ease-out), z-index 0s;
    z-index: 1;
  }

  .card-link {
    display: block;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
  }

  .card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: var(--surface);
    overflow: hidden;
    border-radius: var(--radius);
  }

  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--dur-slow) var(--ease-out);
  }

  /* crop marks — appear on hover, the print-room signature */
  .card-marks {
    position: absolute;
    inset: 10px;
    opacity: 0;
    transition: opacity var(--dur) var(--ease-out);
    pointer-events: none;
  }

  .card-marks::before,
  .card-marks::after {
    content: "";
    position: absolute;
    width: 12px;
    height: 12px;
  }

  .card-marks::before {
    top: 0;
    left: 0;
    border-top: 1.5px solid #fff;
    border-left: 1.5px solid #fff;
  }

  .card-marks::after {
    bottom: 0;
    right: 0;
    border-bottom: 1.5px solid #fff;
    border-right: 1.5px solid #fff;
  }

  .card-bar {
    display: flex;
    justify-content: space-between;
    gap: var(--s2);
    margin-top: var(--s3);
    color: var(--ink-50);
  }

  .card-title {
    margin: var(--s1) 0 0;
    font-size: 0.9375rem;
    font-weight: 650;
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .card-stamp {
    display: flex;
    align-items: center;
    gap: var(--s2);
    margin-top: var(--s1);
  }

  .card-stamp.is-fresh {
    color: var(--ink);
    font-weight: 600;
  }

  .card-stamp.is-aging {
    color: var(--ink-50);
  }

  .card-stamp.is-old {
    color: var(--ink-35);
  }

  .card-stamp.is-superseded {
    color: var(--ink-35);
  }

  .card-stamp.is-superseded > span:first-of-type {
    text-decoration: line-through;
  }

  .superseded-mark {
    color: var(--accent);
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
  }

  /* ---- hover / expanded state (driven by .is-open from grid JS) ---- */
  .card-digest {
    position: absolute;
    top: calc(100% + var(--s2));
    left: 0;
    right: 0;
    background: var(--surface);
    border: 1px solid var(--hairline);
    border-radius: var(--radius);
    padding: var(--s4);
    opacity: 0;
    transform: translateY(-4px);
    visibility: hidden;
    transition:
      opacity var(--dur) var(--ease-out),
      transform var(--dur) var(--ease-out),
      visibility 0s linear var(--dur);
    box-shadow: 0 24px 48px -16px rgba(19, 19, 18, 0.18);
    z-index: 2;
  }

  .digest-what {
    margin: 0;
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .digest-why {
    margin: var(--s3) 0 0;
    font-size: 0.875rem;
    line-height: 1.55;
    color: var(--ink-70);
    border-left: 2px solid var(--accent);
    padding-left: var(--s3);
  }

  .digest-stack {
    margin: var(--s4) 0 0;
    color: var(--ink-50);
  }

  .card.is-open {
    z-index: 20;
    transform: scale(1.04);
  }

  .card.is-open .card-media img {
    transform: scale(1.05);
  }

  .card.is-open .card-marks {
    opacity: 0.9;
  }

  .card.is-open .card-digest {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    transition-delay: 0s;
  }
</style>
