<footer class="footer" id="newsletter" transition:persist="footer">
  <div class="footer-bar">
    <a class="f-brand" href="/" aria-label="Full Bleed home">
      <span class="f-mark">FULL BLEED</span>
      <span class="reg" aria-hidden="true">⌖</span>
    </a>

    <form class="f-form" id="nl-form" novalidate>
      <input id="nl-email" type="email" required placeholder="you@studio.com — the weekly-ish best" aria-label="Email address for the weekly-ish best of Full Bleed" />
      <button type="submit">Join</button>
    </form>

    <nav class="f-links" aria-label="Footer">
      <a href="/about/">About</a>
      <a href="/about/">Credit &amp; takedown</a>
      <a href="#newsletter">Newsletter</a>
    </nav>
  </div>
  <p class="f-fine" id="nl-fine" hidden></p>
</footer>

<style>
  .footer {
    padding: 0 var(--s4) var(--s4);
  }

  .footer-bar {
    max-width: calc(var(--maxw) - 2 * var(--s4));
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-rest);
    padding: var(--s3) var(--s5, 1.25rem);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--s4);
  }

  /* ---- brand (left) ---- */
  .f-brand {
    justify-self: start;
    display: inline-flex;
    align-items: baseline;
    text-decoration: none;
    color: var(--ink);
  }

  .f-mark {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  .reg {
    color: var(--accent);
    font-size: 0.5rem;
    vertical-align: super;
    margin-left: 0.3em;
  }

  /* ---- email (center) ---- */
  .f-form {
    justify-self: center;
    display: flex;
    gap: var(--s2);
    width: clamp(280px, 34vw, 440px);
  }

  .f-form input {
    flex: 1;
    min-width: 0;
    height: 40px;
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    background: var(--paper);
    padding: 0 var(--s4);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--ink);
    transition: border-color var(--dur-fast) var(--ease-out), box-shadow var(--dur) var(--ease-out);
  }

  .f-form input::placeholder {
    color: var(--ink-35);
  }

  .f-form input:focus {
    outline: none;
    border-color: var(--ink);
    box-shadow: var(--shadow-rest);
  }

  .f-form button {
    height: 40px;
    padding: 0 var(--s5, 1.25rem);
    border: none;
    border-radius: var(--r-pill);
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: var(--w-med);
    transition: transform var(--dur-fast) var(--ease-spring), opacity var(--dur-fast) var(--ease-out);
  }

  .f-form button:hover {
    opacity: 0.85;
  }

  .f-form button:active {
    transform: scale(0.95);
  }

  /* ---- links (right) ---- */
  .f-links {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--s4);
  }

  .f-links a {
    font-size: 0.8125rem;
    font-weight: var(--w-med);
    color: var(--ink-50);
    text-decoration: none;
    white-space: nowrap;
    transition: color var(--dur-fast) var(--ease-out);
  }

  .f-links a:hover {
    color: var(--ink);
  }

  .f-fine {
    max-width: calc(var(--maxw) - 2 * var(--s4));
    margin: var(--s2) auto 0;
    text-align: center;
    font-size: 0.75rem;
    color: var(--ink);
  }

  /* ---- mobile: stack the three zones ---- */
  @media (max-width: 820px) {
    .footer-bar {
      grid-template-columns: 1fr;
      justify-items: center;
      gap: var(--s3);
      padding: var(--s4) var(--s4);
    }

    .f-brand,
    .f-form,
    .f-links {
      justify-self: center;
    }

    .f-form {
      width: 100%;
    }
  }
</style>

<script>
  // email capture lands with launch — until then, honest local note
  document.addEventListener("submit", (e) => {
    const form = e.target as HTMLFormElement;
    if (form.id !== "nl-form") return;
    e.preventDefault();
    const email = (document.getElementById("nl-email") as HTMLInputElement).value.trim();
    const fine = document.getElementById("nl-fine")!;
    if (!email || !email.includes("@")) {
      fine.hidden = false;
      fine.textContent = "That email doesn't look right — try again?";
      return;
    }
    localStorage.setItem("fb-newsletter-intent", email);
    form.querySelector("input")!.setAttribute("disabled", "");
    form.querySelector("button")!.setAttribute("disabled", "");
    fine.hidden = false;
    fine.textContent = "✓ Noted — the list goes live with launch, and you're first on it.";
  });
</script>
