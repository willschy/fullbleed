<style>
  .footer {
    padding: 0 var(--s4) var(--s4);
  }

  .footer-card {
    max-width: calc(var(--maxw) - 2 * var(--s4));
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--r-xl);
    box-shadow: var(--shadow-rest);
    padding: var(--s8) var(--s8) var(--s6);
  }

  /* ---- top: CTA left, nav right ---- */
  .f-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s8);
  }

  @media (min-width: 760px) {
    .f-top {
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--s12);
      align-items: start;
    }
  }

  .f-cta {
    max-width: 440px;
  }

  .f-kicker {
    margin: 0 0 var(--s2);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-35);
  }

  .f-head {
    margin: 0 0 var(--s5, 1.25rem);
    font-size: clamp(1.25rem, 2.2vw, 1.5rem);
    font-weight: var(--w-display);
    letter-spacing: -0.015em;
    line-height: 1.25;
  }

  .f-row {
    display: flex;
    gap: var(--s2);
    margin-top: var(--s4);
  }

  .f-row input {
    flex: 1;
    min-width: 0;
    height: 46px;
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    background: var(--paper);
    padding: 0 var(--s4);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--ink);
    transition: border-color var(--dur-fast) var(--ease-out), box-shadow var(--dur) var(--ease-out);
  }

  .f-row input::placeholder {
    color: var(--ink-35);
  }

  .f-row input:focus {
    outline: none;
    border-color: var(--ink);
    box-shadow: var(--shadow-rest);
  }

  .f-row button {
    height: 46px;
    padding: 0 var(--s6);
    border: none;
    border-radius: var(--r-pill);
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: var(--w-med);
    transition: transform var(--dur-fast) var(--ease-spring), opacity var(--dur-fast) var(--ease-out);
  }

  .f-row button:hover {
    opacity: 0.85;
  }

  .f-row button:active {
    transform: scale(0.96);
  }

  .f-fine {
    margin: var(--s3) 0 0;
    font-size: 0.75rem;
    color: var(--ink-35);
    transition: color var(--dur) var(--ease-out);
  }

  .f-fine.is-done {
    color: var(--ink);
  }

  /* ---- nav, right-aligned ---- */
  .f-nav {
    display: flex;
