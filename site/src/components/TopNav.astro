---
---

<header class="topnav">
  <div class="topnav-inner">
    <a class="wordmark" href="/" aria-label="Full Bleed home">
      FULL BLEED<span class="reg" aria-hidden="true">⌖</span>
    </a>

    <form class="search" role="search" action="/" method="get">
      <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <path d="m20 20-3.5-3.5" />
      </svg>
      <input id="search-input" name="q" type="search" placeholder="Search the catalog…" autocomplete="off" aria-label="Search the catalog" />
      <kbd class="search-kbd" aria-hidden="true">/</kbd>
    </form>

    <nav class="topnav-links" aria-label="Site">
      <a href="/about/" class="topnav-link">About</a>
      <a href="#newsletter" class="topnav-link">Newsletter</a>
      <button class="theme-btn" id="theme-toggle" aria-label="Toggle dark mode">
        <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.5" />
          <path d="M12 2.5v2.5M12 19v2.5M2.5 12H5m14 0h2.5M5 5l1.8 1.8M17.2 17.2 19 19M19 5l-1.8 1.8M6.8 17.2 5 19" />
        </svg>
        <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .topnav-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--s6);
    height: 60px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--s6);
  }

  .wordmark {
    justify-self: start;
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1;
    letter-spacing: 0.01em;
    text-decoration: none;
    white-space: nowrap;
  }

  .reg {
    color: var(--accent);
    font-family: var(--font-sans);
    font-weight: var(--w-body);
    font-size: 0.42em;
    vertical-align: super;
    margin-left: 0.25em;
  }

  /* search sits dead-center of the page */
  .search {
    position: relative;
    width: min(440px, 42vw);
  }

  .search-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-35);
    pointer-events: none;
  }

  .search input {
    width: 100%;
    height: 38px;
    border: 1px solid transparent;
    border-radius: var(--r-pill);
    background: var(--fill-1);
    padding: 0 var(--s4) 0 38px;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--ink);
    transition:
      background var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }

  .search input::placeholder {
    color: var(--ink-35);
  }

  .search input:hover {
    background: var(--fill-2);
  }

  .search input:focus {
    outline: none;
    background: var(--surface);
    border-color: var(--hairline);
    box-shadow: var(--shadow-rest);
  }

  .topnav-links {
    justify-self: end;
    display: flex;
    gap: var(--s2);
  }

  .topnav-link {
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: var(--w-med);
    color: var(--ink-50);
    padding: var(--s2) var(--s3);
    border-radius: var(--r-pill);
    transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }

  .topnav-link:hover {
    color: var(--ink);
    background: var(--fill-1);
  }

  .theme-btn {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border: none;
    background: none;
    border-radius: var(--r-pill);
    color: var(--ink-50);
    transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-spring);
  }

  .theme-btn:hover {
    color: var(--ink);
    background: var(--fill-1);
  }

  .theme-btn:active {
    transform: scale(0.9);
  }

  .icon-sun {
    display: none;
  }

  :global(html[data-theme="dark"]) .icon-sun {
    display: block;
  }

  :global(html[data-theme="dark"]) .icon-moon {
    display: none;
  }

  .search-kbd {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 6px;
    border: 1px solid var(--hairline);
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--ink-35);
    pointer-events: none;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .search input:focus ~ .search-kbd {
    opacity: 0;
  }

  @media (max-width: 720px) {
    .search-kbd {
      display: none;
    }

    .topnav-inner {
      grid-template-columns: auto 1fr;
      gap: var(--s4);
      padding: 0 var(--s4);
    }

    .search {
      width: 100%;
      justify-self: stretch;
    }

    .topnav-links {
      display: none;
    }
  }
</style>

<script>
  // theme toggle — persisted, survives client-side routing
  document.addEventListener("click", (e) => {
    if (!(e.target as HTMLElement).closest("#theme-toggle")) return;
    const html = document.documentElement;
    const next = html.dataset.theme === "dark" ? "light" : "dark";
    html.dataset.theme = next;
    localStorage.setItem("fb-theme", next);
  });

  // search submit: on the catalog, filtering is live (don't reload);
  // from any other page, let it navigate to /?q=… and filter on arrival
  document.addEventListener("submit", (e) => {
    const form = e.target as HTMLElement;
    if (form.classList?.contains("search") && document.getElementById("grid")) {
      e.preventDefault();
    }
  });

  // "/" focuses search from anywhere (Linear/GitHub convention)
  document.addEventListener("keydown", (e) => {
    if (e.key !== "/" || e.metaKey || e.ctrlKey || e.altKey) return;
    const t = e.target as HTMLElement;
    if (t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.isContentEditable) return;
    const input = document.getElementById("search-input");
    if (input) {
      e.preventDefault();
      input.focus();
    }
  });
</script>
