---
---

<header class="topnav" transition:persist="topnav" transition:name="fb-nav">
  <div class="topnav-inner">
    <a class="wordmark" href="/" aria-label="Full Bleed home">
      FULL BLEED<span class="reg" aria-hidden="true">⌖</span>
    </a>

    <form class="search" role="search" action="/" method="get">
      <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <path d="m20 20-3.5-3.5" />
      </svg>
      <input id="search-input" name="q" type="search" placeholder="Search the catalog…" autocomplete="off" aria-label="Search the catalog" />
      <kbd class="search-kbd" aria-hidden="true">/</kbd>
    </form>

    <nav class="topnav-links" aria-label="Site">
      <a href="/about/" class="topnav-link">About</a>
      <a href="#newsletter" class="topnav-link">Newsletter</a>
      <a class="topnav-saved" id="saved-toggle" href="/?saved=1" aria-pressed="false" aria-label="Saved items">
        <svg class="saved-ico" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
          <path d="M6 4.5h12a1 1 0 0 1 1 1v14l-7-4-7 4v-14a1 1 0 0 1 1-1z" />
        </svg>
        <span>Saved</span>
        <span class="saved-badge" data-saved-count hidden>0</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 40;
    /* solid fill, no backdrop-filter — blur repaints a frame late during the
       page swap, which reads as the nav "refreshing". A solid paper bar paints
       instantly and stays rock-steady across navigations (it is persisted). */
    background: var(--paper);
    border-bottom: 1px solid var(--hairline);
  }

  .topnav-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--s6);
    height: 60px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--s6);
  }

  .wordmark {
    justify-self: start;
    font-family: var(--font-display);
    font-size: 1.375rem;
    line-height: 1;
    letter-spacing: 0.01em;
    text-decoration: none;
    white-space: nowrap;
  }

  .reg {
    color: var(--accent);
    font-family: var(--font-sans);
    font-weight: var(--w-body);
    font-size: 0.42em;
    vertical-align: super;
    margin-left: 0.25em;
  }

  /* search sits dead-center of the page */
  .search {
    position: relative;
    width: min(440px, 42vw);
  }

  .search-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-35);
    pointer-events: none;
  }

  .search input {
    width: 100%;
    height: 38px;
    border: 1px solid transparent;
    border-radius: var(--r-pill);
    background: var(--fill-1);
    padding: 0 var(--s4) 0 38px;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--ink);
    transition:
      background var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }

  .search input::placeholder {
    color: var(--ink-35);
  }

  .search input:hover {
    background: var(--fill-2);
  }

  .search input:focus {
    outline: none;
    background: var(--surface);
    border-color: var(--hairline);
    box-shadow: var(--shadow-rest);
  }

  .topnav-links {
    justify-self: end;
    display: flex;
    gap: var(--s2);
  }

  .topnav-link {
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: var(--w-med);
    color: var(--ink-50);
    padding: var(--s2) var(--s3);
    border-radius: var(--r-pill);
    transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }

  .topnav-link:hover {
    color: var(--ink);
    background: var(--fill-1);
  }

  /* Saved — utility nav, far top-right (convention for a personal saved view) */
  .topnav-saved {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: var(--w-med);
    color: var(--ink-50);
    padding: var(--s2) var(--s3);
    border-radius: var(--r-pill);
    transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }

  .topnav-saved .saved-ico {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linejoin: round;
    transition: fill var(--dur-fast) var(--ease-out);
  }

  .topnav-saved:hover {
    color: var(--ink);
    background: var(--fill-1);
  }

  .topnav-saved.is-active {
    color: var(--accent);
  }

  .topnav-saved.is-active .saved-ico {
    fill: var(--accent);
    stroke: var(--accent);
  }

  .saved-badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    line-height: 1;
    padding: 2px 5px;
    min-width: 15px;
    text-align: center;
    border-radius: var(--r-pill);
    background: var(--fill-2);
    color: var(--ink-70);
  }

  .topnav-saved.is-active .saved-badge {
    background: var(--accent);
    color: #fff;
  }

  .search-kbd {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 6px;
    border: 1px solid var(--hairline);
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--ink-35);
    pointer-events: none;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .search input:focus ~ .search-kbd {
    opacity: 0;
  }

  @media (max-width: 720px) {
    .search-kbd {
      display: none;
    }

    /* two-row header: brand + Saved on top, full-width search beneath */
    .topnav-inner {
      grid-template-columns: 1fr auto;
      grid-template-rows: auto auto;
      column-gap: var(--s4);
      row-gap: var(--s3);
      height: auto;
      padding: var(--s4) var(--s4) var(--s3);
      align-items: center;
    }

    .wordmark {
      grid-column: 1;
      grid-row: 1;
    }

    .topnav-links {
      grid-column: 2;
      grid-row: 1;
      justify-self: end;
      gap: 0;
    }

    .topnav-link {
      display: none;
    }

    .topnav-saved {
      gap: 4px;
      padding: var(--s2);
    }

    .topnav-saved > span:not(.saved-badge) {
      display: none;
    }

    .search {
      grid-column: 1 / -1;
      grid-row: 2;
      width: 100%;
    }
  }
</style>

<script>
  // search submit: on the catalog, filtering is live (don't reload);
  // from any other page, let it navigate to /?q=… and filter on arrival
  document.addEventListener("submit", (e) => {
    const form = e.target as HTMLElement;
    if (form.classList?.contains("search") && document.getElementById("grid")) {
      e.preventDefault();
    }
  });

  // "/" focuses search from anywhere (Linear/GitHub convention)
  document.addEventListener("keydown", (e) => {
    if (e.key !== "/" || e.metaKey || e.ctrlKey || e.altKey) return;
    const t = e.target as HTMLElement;
    if (t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.isContentEditable) return;
    const input = document.getElementById("search-input");
    if (input) {
      e.preventDefault();
      input.focus();
    }
  });
</script>
