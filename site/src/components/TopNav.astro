---
interface Props {
  showSearch?: boolean;
}

const { showSearch = false } = Astro.props;
---

<header class="topnav">
  <div class="topnav-inner">
    <a class="wordmark" href="/" aria-label="Full Bleed home">
      FULL BLEED<span class="reg" aria-hidden="true">⌖</span>
    </a>

    {showSearch && (
      <div class="search">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" />
        </svg>
        <input id="search-input" type="search" placeholder="Search the catalog…" autocomplete="off" aria-label="Search the catalog" />
      </div>
    )}

    <nav class="topnav-links meta" aria-label="Site">
      <a href="/about/" class="topnav-link">About</a>
      <a href="#newsletter" class="topnav-link">Newsletter</a>
    </nav>
  </div>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--paper) 94%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--hairline);
  }

  .topnav-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--s6);
    height: 56px;
    display: flex;
    align-items: center;
    gap: var(--s8);
  }

  .wordmark {
    font-size: 1.0625rem;
    font-weight: var(--w-display);
    letter-spacing: 0.01em;
    text-decoration: none;
    white-space: nowrap;
    flex: none;
  }

  .reg {
    color: var(--accent);
    font-weight: var(--w-body);
    font-size: 0.6em;
    vertical-align: super;
    margin-left: 0.2em;
  }

  .search {
    position: relative;
    flex: 1;
    max-width: 420px;
  }

  .search-icon {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-35);
    pointer-events: none;
  }

  .search input {
    width: 100%;
    height: 36px;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    background: var(--surface);
    padding: 0 var(--s4) 0 34px;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--ink);
    transition: border-color var(--dur-fast) var(--ease-out);
  }

  .search input::placeholder {
    color: var(--ink-35);
  }

  .search input:hover {
    border-color: var(--ink-35);
  }

  .search input:focus {
    outline: none;
    border-color: var(--ink);
  }

  .topnav-links {
    margin-left: auto;
    display: flex;
    gap: var(--s6);
  }

  .topnav-link {
    text-decoration: none;
    color: var(--ink-50);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .topnav-link:hover {
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .topnav-inner {
      gap: var(--s4);
      padding: 0 var(--s4);
    }

    .topnav-links {
      display: none;
    }
  }
</style>
