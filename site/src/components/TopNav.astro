---
interface Props {
  showSearch?: boolean;
}

const { showSearch = false } = Astro.props;
---

<header class="topnav">
  <div class="topnav-inner" data-search={showSearch ? "true" : "false"}>
    <a class="wordmark" href="/" aria-label="Full Bleed home">
      FULL BLEED<span class="reg" aria-hidden="true">⌖</span>
    </a>

    {showSearch && (
      <div class="search">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" />
        </svg>
        <input id="search-input" type="search" placeholder="Search the catalog…" autocomplete="off" aria-label="Search the catalog" />
        <kbd class="search-kbd" aria-hidden="true">/</kbd>
      </div>
    )}

    <nav class="topnav-links" aria-label="Site">
      <a href="/about/" class="topnav-link">About</a>
      <a href="#newsletter" class="topnav-link">Newsletter</a>
    </nav>
  </div>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .topnav-inner {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 var(--s6);
    height: 60px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--s6);
  }

  .wordmark {
    justify-self: start;
    font-size: 1rem;
    font-weight: var(--w-display);
    letter-spacing: 0.01em;
    text-decoration: none;
    white-space: nowrap;
  }

  .reg {
    color: var(--accent);
    font-weight: var(--w-body);
    font-size: 0.6em;
    vertical-align: super;
    margin-left: 0.2em;
  }

  /* search sits dead-center of the page */
  .search {
    position: relative;
    width: min(440px, 42vw);
  }

  .search-icon {
    position: absolute;
    left: 15px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ink-35);
    pointer-events: none;
  }

  .search input {
    width: 100%;
    height: 38px;
    border: 1px solid transparent;
    border-radius: var(--r-pill);
    background: rgba(19, 19, 18, 0.05);
    padding: 0 var(--s4) 0 38px;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--ink);
    transition:
      background var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out),
      box-shadow var(--dur) var(--ease-out);
  }

  .search input::placeholder {
    color: var(--ink-35);
  }

  .search input:hover {
    background: rgba(19, 19, 18, 0.07);
  }

  .search input:focus {
    outline: none;
    background: var(--surface);
    border-color: var(--hairline);
    box-shadow: var(--shadow-rest);
  }

  .topnav-links {
    justify-self: end;
    display: flex;
    gap: var(--s2);
  }

  .topnav-link {
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: var(--w-med);
    color: var(--ink-50);
    padding: var(--s2) var(--s3);
    border-radius: var(--r-pill);
    transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }

  .topnav-link:hover {
    color: var(--ink);
    background: rgba(19, 19, 18, 0.05);
  }

  .search-kbd {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    border-radius: 6px;
    border: 1px solid var(--hairline);
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--ink-35);
    pointer-events: none;
    transition: opacity var(--dur-fast) var(--ease-out);
  }

  .search input:focus ~ .search-kbd {
    opacity: 0;
  }

  @media (max-width: 720px) {
    .search-kbd {
      display: none;
    }

    .topnav-inner {
      grid-template-columns: auto 1fr;
      gap: var(--s4);
      padding: 0 var(--s4);
    }

    .search {
      width: 100%;
      justify-self: stretch;
    }

    .topnav-links {
      display: none;
    }
  }
</style>

<script>
  // "/" focuses search from anywhere (Linear/GitHub convention)
  document.addEventListener("keydown", (e) => {
    if (e.key !== "/" || e.metaKey || e.ctrlKey || e.altKey) return;
    const t = e.target as HTMLElement;
    if (t.tagName === "INPUT" || t.tagName === "TEXTAREA" || t.isContentEditable) return;
    const input = document.getElementById("search-input");
    if (input) {
      e.preventDefault();
      input.focus();
    }
  });
</script>
