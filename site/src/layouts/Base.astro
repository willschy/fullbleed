---
import { ClientRouter } from "astro:transitions";
import TopNav from "../components/TopNav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A curated, always-fresh catalog of groundbreaking real-world AI work — for working creatives, by working creatives." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {/* TODO: remove at public launch — keeps placeholder/fixture content out of search indexes */}
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Climate+Crisis&family=Rubik:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
    <script is:inline>
      // Full Bleed is dark-only. Mark the document after the first client-side swap so
      // entrance animations run only on the very first load, not on every route change.
      document.addEventListener("astro:after-swap", () => {
        document.documentElement.classList.add("vt-nav");
      });
    </script>

    <script is:inline>
      // bookmarks — localStorage, no account. Global + delegated so it works
      // on every page and survives client-side navigation.
      (function () {
        const KEY = "fb-saved";
        const read = () => {
          try { return new Set(JSON.parse(localStorage.getItem(KEY) || "[]")); }
          catch { return new Set(); }
        };
        const write = (set) => localStorage.setItem(KEY, JSON.stringify([...set]));

        // expose for the catalog filter
        window.fbSaved = {
          has: (id) => read().has(id),
          count: () => read().size,
        };

        function syncUI() {
          const saved = read();
          document.querySelectorAll("[data-bookmark]").forEach((btn) => {
            const on = saved.has(btn.dataset.id);
            btn.classList.toggle("is-saved", on);
            btn.setAttribute("aria-pressed", String(on));
            const label = btn.querySelector("[data-bookmark-label]");
            if (label) label.textContent = on ? "Saved" : "Save";
          });
          document.querySelectorAll("[data-saved-count]").forEach((el) => {
            el.textContent = String(saved.size);
            el.toggleAttribute("hidden", saved.size === 0); // badge only shows when > 0
          });
        }

        document.addEventListener("click", (e) => {
          const btn = e.target.closest("[data-bookmark]");
          if (!btn) return;
          e.preventDefault();
          e.stopPropagation();
          const set = read();
          const id = btn.dataset.id;
          if (set.has(id)) set.delete(id); else set.add(id);
          write(set);
          syncUI();
          document.dispatchEvent(new CustomEvent("fb-saved-changed"));
        });

        syncUI();
        document.addEventListener("astro:page-load", syncUI);
      })();
    </script>
  </head>
  <body>
    <TopNav />
    <slot />
    <Footer />
  </body>
</html>
