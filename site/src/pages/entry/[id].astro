---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Card from "../../components/Card.astro";

export async function getStaticPaths() {
  const entries = await getCollection("entries");
  return entries.map((entry) => ({ params: { id: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);

const CATEGORY_LABELS: Record<string, string> = {
  "tools": "Tools",
  "automations": "Automations",
  "models": "Models",
  "plugins-skills": "Plugins & Skills",
  "papers": "Papers",
};

const ageDays = (Date.now() - d.date.valueOf()) / 86_400_000;
const freshness = d.supersededBy ? "superseded" : ageDays <= 30 ? "fresh" : ageDays <= 180 ? "aging" : "old";
const stamp = d.date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" });

const allEntries = await getCollection("entries");
const successor = d.supersededBy ? allEntries.find((e) => e.id === d.supersededBy) : null;
const related = allEntries
  .filter((e) => e.id !== entry.id && e.data.category === d.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Base title={`${d.title} — Full Bleed`} description={d.hoverWhat}>
  <main class="entry">
    <figure class="hero">
      {d.thumbnail && (
        <img src={d.thumbnail} alt={d.title} width="1200" height="800" transition:name="fb-cover" />
      )}
      <a class="hero-back" href="/">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 12H5m6-7-7 7 7 7" />
        </svg>
        Catalog
      </a>
      {successor && (
        <a class="hero-superseded" href={`/entry/${successor.id}/`}>
          <span class="sup-label">Superseded</span>
          <span>A newer approach replaced this — see “{successor.data.title}”</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14m-7-7 7 7-7 7" />
          </svg>
        </a>
      )}
    </figure>

    <div class="layout">
      <div class="main-col">
        <div class="titleblock">
          <h1>{d.title}</h1>
          <p class="standfirst">{d.hoverWhat}</p>
        </div>

        <article class="body">
          <Content />
        </article>
      </div>

      <aside class="infocard">
        <button class="save-btn" type="button" data-bookmark data-id={entry.id} aria-pressed="false">
          <svg class="save-icon" viewBox="0 0 24 24" width="15" height="15" aria-hidden="true">
            <path d="M6 4.5h12a1 1 0 0 1 1 1v14l-7-4-7 4v-14a1 1 0 0 1 1-1z" />
          </svg>
          <span data-bookmark-label>Save</span>
        </button>

        <div class="info-section">
          <p class="info-label">Category</p>
          <span class="pill pill-ink">{CATEGORY_LABELS[d.category]}</span>
        </div>

        <div class="info-section">
          <p class="info-label">Stack</p>
          <div class="pill-row">
            {d.tools.map((t) => <span class="pill">{t}</span>)}
          </div>
          {d.modelVersions && <p class="info-fine">{d.modelVersions}</p>}
        </div>

        <div class="info-section">
          <p class="info-label">Freshness</p>
          <p class={`info-fresh is-${freshness}`}>
            {freshness === "fresh" && <span class="dot" aria-hidden="true"></span>}
            {stamp}
          </p>
        </div>

        <div class="info-section">
          <p class="info-label">Source</p>
          <a class="info-link" href={d.source.permalink} rel="noopener">
            {d.source.author} · via {d.source.origin}
          </a>
          {d.source.outboundUrl && (
            <a class="info-link" href={d.source.outboundUrl} rel="noopener">Project link ↗</a>
          )}
        </div>

        {d.credit && (
          <div class="info-section">
            <p class="info-label">Cover</p>
            <a class="info-link" href="https://unsplash.com/?utm_source=full_bleed&utm_medium=referral" rel="noopener">
              Photo: {d.credit}
            </a>
          </div>
        )}

        <p class="info-credit">Their work. We just pointed at it.</p>
      </aside>
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2 class="related-label">More {CATEGORY_LABELS[d.category]}</h2>
        <div class="related-grid">
          {related.map((e, i) => <Card entry={e} index={i} />)}
        </div>
      </section>
    )}
  </main>
</Base>

<style>
  .entry {
    max-width: 1180px;
    margin: 0 auto;
    padding: var(--s4) var(--s6) var(--s16);
  }

  /* ---------- hero ---------- */
  .hero {
    position: relative;
    margin: 0;
    border-radius: var(--r-xl);
    overflow: hidden;
    box-shadow: var(--shadow-rest);
    animation: hero-in 0.6s var(--ease-out) backwards;
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.995);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  .hero img {
    width: 100%;
    max-height: 64vh;
    object-fit: cover;
    /* radius on the img itself keeps view-transition snapshots rounded mid-morph */
    border-radius: var(--r-xl);
  }

  .hero-back {
    position: absolute;
    top: 16px;
    left: 16px;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 14px;
    border-radius: var(--r-pill);
    background: var(--glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    box-shadow: 0 2px 12px rgba(10, 10, 9, 0.12);
    font-size: 0.8125rem;
    font-weight: var(--w-med);
    color: var(--ink);
    text-decoration: none;
    transition: transform var(--dur-fast) var(--ease-spring), box-shadow var(--dur-fast) var(--ease-out);
  }

  .hero-back:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(10, 10, 9, 0.18);
  }

  .hero-superseded {
    position: absolute;
    inset-inline: 16px;
    bottom: 16px;
    display: flex;
    align-items: center;
    gap: var(--s3);
    padding: var(--s3) var(--s4);
    border-radius: var(--r-md);
    background: var(--glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    font-size: 0.8438rem;
    font-weight: var(--w-med);
    color: var(--ink);
    text-decoration: none;
    transition: transform var(--dur-fast) var(--ease-out);
  }

  .hero-superseded:hover {
    transform: translateY(-2px);
  }

  .sup-label {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.6563rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    flex: none;
  }

  .hero-superseded svg {
    margin-left: auto;
    flex: none;
    color: var(--ink-50);
  }

  /* ---------- two-column layout ---------- */
  .layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--s8);
    margin-top: var(--s8);
  }

  @media (min-width: 900px) {
    .layout {
      grid-template-columns: minmax(0, 1fr) 300px;
      gap: var(--s12);
    }
  }

  .titleblock h1 {
    margin: 0;
    font-size: clamp(1.625rem, 3.6vw, 2.375rem);
    font-weight: var(--w-display);
    letter-spacing: -0.02em;
    line-height: 1.12;
  }

  .standfirst {
    margin: var(--s4) 0 0;
    font-size: 1.0938rem;
    line-height: 1.62;
    color: var(--ink);
  }

  .why {
    margin: var(--s4) 0 0;
    font-size: 1.0938rem;
    line-height: 1.62;
    color: var(--ink-70);
    border-left: 2.5px solid var(--accent);
    padding-left: var(--s4);
  }

  /* ---------- body ---------- */
  .body {
    margin-top: var(--s8);
    font-size: 0.9688rem;
    line-height: 1.7;
    color: var(--ink-70);
  }

  .body :global(h2) {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--ink-35);
    margin: var(--s8) 0 var(--s4);
  }

  .body :global(ol) {
    list-style: none;
    counter-reset: step;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }

  .body :global(ol li) {
    counter-increment: step;
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--r-md);
    padding: var(--s3) var(--s4) var(--s3) 52px;
    box-shadow: 0 1px 2px rgba(19, 19, 18, 0.03);
  }

  .body :global(ol li)::before {
    content: counter(step);
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--border-soft);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--ink);
  }

  .body :global(p) {
    margin: 0 0 var(--s3);
  }

  /* ---------- info card ---------- */
  .infocard {
    align-self: start;
    position: sticky;
    top: 76px;
    background: var(--surface);
    border: 1px solid var(--border-soft);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-rest);
    padding: var(--s6);
    display: flex;
    flex-direction: column;
    gap: var(--s6);
    animation: hero-in 0.6s var(--ease-out) 0.12s backwards;
  }

  .save-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--s2);
    width: 100%;
    padding: var(--s3);
    border: 1px solid var(--hairline);
    border-radius: var(--r-pill);
    background: var(--paper);
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: var(--w-med);
    color: var(--ink);
    transition: border-color var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-spring);
  }

  .save-btn:hover {
    border-color: var(--ink-35);
  }

  .save-btn:active {
    transform: scale(0.97);
  }

  .save-icon {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.8;
    stroke-linejoin: round;
    transition: fill 0.2s var(--ease-out);
  }

  .save-btn.is-saved {
    border-color: var(--accent);
    color: var(--accent);
  }

  .save-btn.is-saved .save-icon {
    fill: var(--accent);
    stroke: var(--accent);
  }

  .info-label {
    margin: 0 0 var(--s2);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-35);
  }

  .pill-row {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
  }

  .pill {
    display: inline-block;
    padding: 5px 11px;
    border-radius: var(--r-pill);
    background: var(--fill-1);
    font-size: 0.75rem;
    font-weight: var(--w-med);
    color: var(--ink-70);
  }

  .pill-ink {
    background: var(--ink);
    color: var(--paper);
  }

  .info-fine {
    margin: var(--s2) 0 0;
    font-size: 0.75rem;
    color: var(--ink-35);
  }

  .info-fresh {
    margin: 0;
    display: flex;
    align-items: center;
    gap: var(--s2);
    font-size: 0.8438rem;
    font-weight: var(--w-med);
  }

  .info-fresh.is-aging,
  .info-fresh.is-old {
    color: var(--ink-50);
  }

  .info-fresh.is-superseded {
    color: var(--ink-35);
    text-decoration: line-through;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
  }

  .info-link {
    display: block;
    font-size: 0.8438rem;
    font-weight: var(--w-med);
    color: var(--ink);
    text-decoration: none;
    padding: var(--s2) 0;
    border-bottom: 1px solid var(--hairline);
    transition: color var(--dur-fast) var(--ease-out);
  }

  .info-link:last-of-type {
    border-bottom: none;
  }

  .info-link:hover {
    color: var(--accent);
  }

  .info-credit {
    margin: 0;
    padding-top: var(--s4);
    border-top: 1px solid var(--hairline);
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--ink-35);
  }

  @media (max-width: 899px) {
    .infocard {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .entry {
      padding: var(--s2) var(--s3) var(--s12);
    }

    .hero {
      border-radius: var(--r-lg);
    }

    .hero img {
      border-radius: var(--r-lg);
      max-height: 48vh;
    }

    .hero-back {
      top: 10px;
      left: 10px;
      padding: 7px 12px;
    }

    .hero-superseded {
      inset-inline: 10px;
      bottom: 10px;
      font-size: 0.7813rem;
    }

    .layout {
      margin-top: var(--s6);
      gap: var(--s6);
    }
  }

  /* ---------- related ---------- */
  .related {
    margin-top: var(--s16);
  }

  .related-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--ink-35);
    margin: 0 0 var(--s4);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--s4);
  }
</style>
