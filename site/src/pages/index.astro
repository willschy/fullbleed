---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Card from "../components/Card.astro";

const entries = (await getCollection("entries")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const categories = [
  { id: "client-work", label: "Client Work" },
  { id: "tools-you-can-steal", label: "Steal This" },
  { id: "new-possible", label: "New Possible" },
  { id: "business-plays", label: "Business Plays" },
].map((c) => ({ ...c, count: entries.filter((e) => e.data.category === c.id).length }));
---

<Base title="Full Bleed — real-world AI work, for working creatives">
  <div class="shell">
    <aside class="side">
      <a class="wordmark" href="/" aria-label="Full Bleed home">
        <span>FULL</span>
        <span>BLEED<span class="reg" aria-hidden="true">⌖</span></span>
      </a>
      <p class="tagline meta">Real work · shown<br />· with the how</p>

      <nav class="cats" aria-label="Catalog filters">
        <button class="cat meta is-active" data-filter="all">
          <span>All</span><span class="count">{entries.length}</span>
        </button>
        {categories.map((c) => (
          <button class="cat meta" data-filter={c.id}>
            <span>{c.label}</span><span class="count">{c.count}</span>
          </button>
        ))}
      </nav>

      <label class="current-toggle meta">
        <input type="checkbox" id="current-only" />
        <span class="switch" aria-hidden="true"></span>
        Current only
      </label>

      <p class="side-foot meta">
        Curated by a working creative.<br />
        Credited to the makers,<br />
        linked to the source.
      </p>
    </aside>

    <main class="catalog">
      <div class="grid" id="grid">
        {entries.map((entry) => <Card entry={entry} />)}
      </div>
      <p class="empty meta" id="empty" hidden>Nothing here yet — the bar stays high.</p>
    </main>
  </div>
</Base>

<style>
  .shell {
    max-width: var(--maxw);
    margin: 0 auto;
  }

  /* ---------- sidebar (desktop) ---------- */
  .side {
    display: flex;
    flex-direction: column;
    gap: var(--s6);
    padding: var(--s8) var(--s6);
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    font-size: 2.5rem;
    font-weight: var(--w-black);
    letter-spacing: -0.04em;
    line-height: 0.95;
    text-decoration: none;
  }

  .reg {
    color: var(--accent);
    font-weight: var(--w-body);
    font-size: 0.45em;
    vertical-align: super;
    margin-left: 0.2em;
  }

  .tagline {
    color: var(--ink-50);
    margin: 0;
  }

  .cats {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--hairline);
  }

  .cat {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s3);
    background: none;
    border: none;
    border-bottom: 1px solid var(--hairline);
    padding: var(--s3) 0;
    color: var(--ink-50);
    text-align: left;
    transition: color var(--dur-fast) var(--ease-out), padding-left var(--dur-fast) var(--ease-out);
  }

  .cat:hover {
    color: var(--ink);
  }

  .cat.is-active {
    color: var(--ink);
    font-weight: var(--w-title);
  }

  .cat.is-active span:first-child::before {
    content: "●";
    color: var(--accent);
    font-size: 0.6em;
    margin-right: 0.6em;
    vertical-align: 0.15em;
  }

  .count {
    color: var(--ink-35);
    font-weight: var(--w-body);
  }

  .current-toggle {
    display: flex;
    align-items: center;
    gap: var(--s2);
    color: var(--ink-50);
    cursor: pointer;
    user-select: none;
  }

  .current-toggle input {
    position: absolute;
    opacity: 0;
  }

  .switch {
    width: 28px;
    height: 16px;
    border: 1px solid var(--ink-35);
    border-radius: 999px;
    position: relative;
    flex: none;
    transition: background var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }

  .switch::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--ink-35);
    transition: transform var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }

  .current-toggle input:checked + .switch {
    background: var(--ink);
    border-color: var(--ink);
  }

  .current-toggle input:checked + .switch::after {
    transform: translateX(12px);
    background: var(--paper);
  }

  .current-toggle input:focus-visible + .switch {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .side-foot {
    color: var(--ink-35);
    margin: 0;
  }

  .catalog {
    padding: var(--s8) var(--s6) var(--s16);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--s8) var(--s6);
  }

  .empty {
    color: var(--ink-50);
    text-align: center;
    padding: var(--s16) 0;
  }

  /* ---------- desktop: pinned sidebar + scrolling grid ---------- */
  @media (min-width: 1024px) {
    .shell {
      display: grid;
      grid-template-columns: 264px 1fr;
    }

    .side {
      position: sticky;
      top: 0;
      height: 100dvh;
      border-right: 1px solid var(--hairline);
    }

    .side-foot {
      margin-top: auto;
    }
  }

  /* ---------- mobile/tablet: stacked header, scrollable filter row ---------- */
  @media (max-width: 1023px) {
    .side {
      gap: var(--s4);
      border-bottom: 1px solid var(--hairline);
      padding-bottom: var(--s4);
    }

    .wordmark {
      flex-direction: row;
      gap: 0.3em;
      font-size: 2rem;
    }

    .cats {
      flex-direction: row;
      overflow-x: auto;
      scrollbar-width: none;
      border-top: none;
      gap: var(--s4);
    }

    .cats::-webkit-scrollbar {
      display: none;
    }

    .cat {
      border-bottom: none;
      white-space: nowrap;
      flex: none;
    }

    .count {
      display: none;
    }

    .side-foot {
      display: none;
    }
  }
</style>

<script>
  const grid = document.getElementById("grid")!;
  const cards = [...grid.querySelectorAll<HTMLElement>(".card")];
  const emptyMsg = document.getElementById("empty")!;
  const canHover = window.matchMedia("(hover: hover)").matches;

  /* ---- hover-expand, no intent delay (desktop) ---- */
  if (canHover) {
    let open: HTMLElement | null = null;
    for (const card of cards) {
      card.addEventListener("mouseenter", () => {
        open?.classList.remove("is-open");
        card.classList.add("is-open");
        open = card;
      });
      card.addEventListener("mouseleave", () => {
        if (open === card) {
          card.classList.remove("is-open");
          open = null;
        }
      });
    }
  } else {
    /* ---- mobile: first tap expands, second tap navigates ---- */
    let open: HTMLElement | null = null;
    for (const card of cards) {
      const link = card.querySelector<HTMLAnchorElement>(".card-link")!;
      link.addEventListener("click", (e) => {
        if (open !== card) {
          e.preventDefault();
          open?.classList.remove("is-open");
          card.classList.add("is-open");
          open = card;
        }
      });
    }
    document.addEventListener("click", (e) => {
      if (open && !open.contains(e.target as Node)) {
        open.classList.remove("is-open");
        open = null;
      }
    });
  }

  /* ---- filtering ---- */
  const cats = [...document.querySelectorAll<HTMLButtonElement>(".cat")];
  const currentOnly = document.getElementById("current-only") as HTMLInputElement;
  let activeCategory = "all";

  function apply() {
    let visible = 0;
    for (const card of cards) {
      const catOk = activeCategory === "all" || card.dataset.category === activeCategory;
      const freshOk = !currentOnly.checked || card.dataset.superseded !== "true";
      const show = catOk && freshOk;
      card.style.display = show ? "" : "none";
      if (show) visible++;
    }
    emptyMsg.hidden = visible > 0;
  }

  for (const cat of cats) {
    cat.addEventListener("click", () => {
      cats.forEach((c) => c.classList.toggle("is-active", c === cat));
      activeCategory = cat.dataset.filter ?? "all";
      apply();
    });
  }
  currentOnly.addEventListener("change", apply);
</script>
