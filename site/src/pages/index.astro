---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import TopNav from "../components/TopNav.astro";
import Card from "../components/Card.astro";

const entries = (await getCollection("entries")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const categories = [
  { id: "client-work", label: "Client Work" },
  { id: "tools-you-can-steal", label: "Steal This" },
  { id: "new-possible", label: "New Possible" },
  { id: "business-plays", label: "Business Plays" },
].map((c) => ({ ...c, count: entries.filter((e) => e.data.category === c.id).length }));

const toolCounts = new Map<string, number>();
for (const e of entries) for (const t of e.data.tools) toolCounts.set(t, (toolCounts.get(t) ?? 0) + 1);
const tools = [...toolCounts.entries()].sort((a, b) => b[1] - a[1]).map(([name, count]) => ({ name, count }));
---

<Base title="Full Bleed — real-world AI work, for working creatives">
  <TopNav showSearch={true} />

  <div class="shell">
    <aside class="rail" aria-label="Catalog filters">
      <section class="facet">
        <h2 class="facet-title meta">Category</h2>
        <button class="facet-row is-active" data-facet="category" data-value="all">
          <span>All</span><span class="count meta">{entries.length}</span>
        </button>
        {categories.map((c) => (
          <button class="facet-row" data-facet="category" data-value={c.id}>
            <span>{c.label}</span><span class="count meta">{c.count}</span>
          </button>
        ))}
      </section>

      <section class="facet">
        <h2 class="facet-title meta">Tool</h2>
        <button class="facet-row is-active" data-facet="tool" data-value="all">
          <span>All</span><span class="count meta">{entries.length}</span>
        </button>
        {tools.map((t) => (
          <button class="facet-row" data-facet="tool" data-value={t.name}>
            <span>{t.name}</span><span class="count meta">{t.count}</span>
          </button>
        ))}
      </section>

      <section class="facet">
        <h2 class="facet-title meta">Freshness</h2>
        <label class="current-toggle">
          <input type="checkbox" id="current-only" />
          <span class="switch" aria-hidden="true"></span>
          <span class="toggle-label">Current only</span>
        </label>
        <p class="facet-hint">Hides superseded workflows — only approaches that are still the best way.</p>
      </section>
    </aside>

    <main class="catalog">
      <div class="resultbar">
        <p class="meta" id="result-count">{entries.length} entries</p>
      </div>
      <div class="grid" id="grid">
        {entries.map((entry) => <Card entry={entry} />)}
      </div>
      <p class="empty meta" id="empty" hidden>Nothing here yet — the bar stays high.</p>
    </main>
  </div>
</Base>

<style>
  .shell {
    max-width: var(--maxw);
    margin: 0 auto;
  }

  /* ---------- left rail ---------- */
  .rail {
    display: flex;
    flex-direction: column;
    gap: var(--s8);
    padding: var(--s8) var(--s6);
  }

  .facet {
    display: flex;
    flex-direction: column;
  }

  .facet-title {
    color: var(--ink-35);
    margin: 0 0 var(--s2);
    font-weight: var(--w-med);
  }

  .facet-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--s3);
    background: none;
    border: none;
    padding: var(--s2) var(--s2);
    margin: 0 calc(-1 * var(--s2));
    border-radius: 4px;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    font-weight: var(--w-body);
    color: var(--ink-70);
    text-align: left;
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }

  .facet-row:hover {
    background: rgba(19, 19, 18, 0.045);
    color: var(--ink);
  }

  .facet-row.is-active {
    color: var(--ink);
    font-weight: var(--w-med);
    background: rgba(19, 19, 18, 0.06);
  }

  .facet-row.is-active span:first-child::before {
    content: "";
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    margin-right: 0.55em;
    vertical-align: 0.18em;
  }

  .count {
    color: var(--ink-35);
  }

  .current-toggle {
    display: flex;
    align-items: center;
    gap: var(--s3);
    padding: var(--s2) 0;
    font-size: 0.875rem;
    color: var(--ink-70);
    cursor: pointer;
    user-select: none;
  }

  .current-toggle input {
    position: absolute;
    opacity: 0;
  }

  .switch {
    width: 30px;
    height: 18px;
    border: 1px solid var(--ink-35);
    border-radius: 999px;
    position: relative;
    flex: none;
    transition: background var(--dur-fast) var(--ease-out), border-color var(--dur-fast) var(--ease-out);
  }

  .switch::after {
    content: "";
    position: absolute;
    top: 2px;
    left: 2px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--ink-35);
    transition: transform var(--dur-fast) var(--ease-out), background var(--dur-fast) var(--ease-out);
  }

  .current-toggle input:checked + .switch {
    background: var(--ink);
    border-color: var(--ink);
  }

  .current-toggle input:checked + .switch::after {
    transform: translateX(12px);
    background: var(--paper);
  }

  .current-toggle input:focus-visible + .switch {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .facet-hint {
    margin: var(--s2) 0 0;
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--ink-35);
  }

  /* ---------- catalog ---------- */
  .catalog {
    padding: var(--s6) var(--s6) var(--s16);
  }

  .resultbar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--s4);
  }

  .resultbar p {
    margin: 0;
    color: var(--ink-35);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--s8) var(--s6);
  }

  .empty {
    color: var(--ink-50);
    text-align: center;
    padding: var(--s16) 0;
  }

  /* ---------- desktop: pinned rail ---------- */
  @media (min-width: 1024px) {
    .shell {
      display: grid;
      grid-template-columns: 232px 1fr;
    }

    .rail {
      position: sticky;
      top: 56px;
      height: calc(100dvh - 56px);
      overflow-y: auto;
      border-right: 1px solid var(--hairline);
    }
  }

  /* ---------- mobile/tablet ---------- */
  @media (max-width: 1023px) {
    .rail {
      flex-direction: row;
      align-items: center;
      gap: var(--s6);
      overflow-x: auto;
      scrollbar-width: none;
      padding: var(--s3) var(--s4);
      border-bottom: 1px solid var(--hairline);
    }

    .rail::-webkit-scrollbar {
      display: none;
    }

    .facet {
      flex-direction: row;
      align-items: center;
      gap: var(--s2);
      flex: none;
    }

    .facet-title {
      margin: 0 var(--s2) 0 0;
    }

    .facet-row {
      white-space: nowrap;
      margin: 0;
    }

    .count,
    .facet-hint {
      display: none;
    }

    .toggle-label {
      white-space: nowrap;
    }

    .catalog {
      padding: var(--s4) var(--s4) var(--s12);
    }
  }
</style>

<script>
  const grid = document.getElementById("grid")!;
  const cards = [...grid.querySelectorAll<HTMLElement>(".card")];
  const emptyMsg = document.getElementById("empty")!;
  const resultCount = document.getElementById("result-count")!;
  const canHover = window.matchMedia("(hover: hover)").matches;

  /* ---- hover-expand, instant (desktop) ---- */
  if (canHover) {
    let open: HTMLElement | null = null;
    for (const card of cards) {
      card.addEventListener("mouseenter", () => {
        open?.classList.remove("is-open");
        card.classList.add("is-open");
        open = card;
      });
      card.addEventListener("mouseleave", () => {
        if (open === card) {
          card.classList.remove("is-open");
          open = null;
        }
      });
    }
  } else {
    /* ---- mobile: first tap expands, second tap navigates ---- */
    let open: HTMLElement | null = null;
    for (const card of cards) {
      const link = card.querySelector<HTMLAnchorElement>(".card-link")!;
      link.addEventListener("click", (e) => {
        if (open !== card) {
          e.preventDefault();
          open?.classList.remove("is-open");
          card.classList.add("is-open");
          open = card;
        }
      });
    }
    document.addEventListener("click", (e) => {
      if (open && !open.contains(e.target as Node)) {
        open.classList.remove("is-open");
        open = null;
      }
    });
  }

  /* ---- faceted filtering + search ---- */
  const facetRows = [...document.querySelectorAll<HTMLButtonElement>(".facet-row")];
  const currentOnly = document.getElementById("current-only") as HTMLInputElement;
  const searchInput = document.getElementById("search-input") as HTMLInputElement | null;
  const state = { category: "all", tool: "all", query: "" };

  function apply() {
    let visible = 0;
    for (const card of cards) {
      const catOk = state.category === "all" || card.dataset.category === state.category;
      const toolOk = state.tool === "all" || (card.dataset.tools ?? "").split("|").includes(state.tool);
      const freshOk = !currentOnly.checked || card.dataset.superseded !== "true";
      const queryOk = state.query === "" || (card.textContent ?? "").toLowerCase().includes(state.query);
      const show = catOk && toolOk && freshOk && queryOk;
      card.style.display = show ? "" : "none";
      if (show) visible++;
    }
    emptyMsg.hidden = visible > 0;
    resultCount.textContent = `${visible} ${visible === 1 ? "entry" : "entries"}`;
  }

  for (const row of facetRows) {
    row.addEventListener("click", () => {
      const facet = row.dataset.facet as "category" | "tool";
      state[facet] = row.dataset.value ?? "all";
      facetRows
        .filter((r) => r.dataset.facet === facet)
        .forEach((r) => r.classList.toggle("is-active", r === row));
      apply();
    });
  }

  currentOnly.addEventListener("change", apply);
  searchInput?.addEventListener("input", () => {
    state.query = searchInput.value.trim().toLowerCase();
    apply();
  });
</script>
