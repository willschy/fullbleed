---
const samples = ["/lab/s1.jpg", "/lab/s2.jpg", "/lab/s3.jpg"];
const cats = [
  { id: "tools", name: "Tools", hi: "#F4C7AE" },
  { id: "automations", name: "Automations", hi: "#F1D8A6" },
  { id: "models", name: "Models", hi: "#BCDFDD" },
  { id: "plugins", name: "Plugins & Skills", hi: "#D5C9EB" },
  { id: "papers", name: "Papers", hi: "#CCDDBB" },
];
---
<html data-theme="dark">
<head><meta charset="utf-8" /><title>Treatment lab</title>
<style>
  body{margin:0;background:#111110;color:#f2f1ec;font-family:system-ui,sans-serif;padding:28px 32px}
  h1{font-size:18px;font-weight:500;margin:0 0 4px}
  .sub{font-family:ui-monospace,monospace;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:rgba(242,241,236,.4);margin:0 0 24px}
  .row{display:grid;grid-template-columns:150px repeat(3,1fr);gap:12px;align-items:center;margin-bottom:10px}
  .lab{display:flex;align-items:center;gap:9px;font-size:13px;font-weight:500}
  .sw{width:14px;height:14px;border-radius:4px;flex:none}
  .thumb{width:100%;height:150px;object-fit:cover;border-radius:12px;display:block}
  .k{font-family:ui-monospace,monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;color:rgba(242,241,236,.4)}
</style>
</head>
<body>
  <h1>Full Bleed — treatment lab</h1>
  <p class="sub">stock duotone, one ink shadow, a category highlight</p>

  <svg width="0" height="0" style="position:absolute">
    <defs>
      {cats.map((c) => {
        const hi = c.hi;
        const r = (parseInt(hi.slice(1,3),16)/255).toFixed(3);
        const g = (parseInt(hi.slice(3,5),16)/255).toFixed(3);
        const b = (parseInt(hi.slice(5,7),16)/255).toFixed(3);
        return (
          <filter id={`d-${c.id}`} color-interpolation-filters="sRGB">
            <feColorMatrix type="matrix" values="0.2126 0.7152 0.0722 0 0 0.2126 0.7152 0.0722 0 0 0.2126 0.7152 0.0722 0 0 0 0 0 1 0" />
            <feComponentTransfer>
              <feFuncR type="table" tableValues={`0.07 ${r}`} />
              <feFuncG type="table" tableValues={`0.07 ${g}`} />
              <feFuncB type="table" tableValues={`0.07 ${b}`} />
            </feComponentTransfer>
          </filter>
        );
      })}
    </defs>
  </svg>

  <div class="row">
    <span class="k">Original</span>
    {samples.map((s) => <img class="thumb" src={s} alt="" />)}
  </div>

  {cats.map((c) => (
    <div class="row">
      <span class="lab"><span class="sw" style={`background:${c.hi}`}></span>{c.name}</span>
      {samples.map((s) => <img class="thumb" src={s} alt="" style={`filter:url(#d-${c.id})`} />)}
    </div>
  ))}
</body>
</html>
